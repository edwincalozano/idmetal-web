---
const navLinks = ['Inicio', 'Servicios', 'Nosotros', 'Proyectos', 'Contacto'];
const services = ['Metalmecánica Industrial', 'Construcción Civil', 'Topografía Especializada'];

const socialLinks = [
  {
    label: 'Facebook',
    href: '#',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`,
  },
  {
    label: 'Instagram',
    href: '#',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
  },
  {
    label: 'LinkedIn',
    href: '#',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>`,
  },
  {
    label: 'YouTube',
    href: '#',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="white"/></svg>`,
  },
];
---

<footer style="background: #0A0A0A;" class="border-t border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <!-- Brand column -->
      <div class="lg:col-span-2">
        <a href="/" class="inline-flex flex-col mb-4" aria-label="IDMETAL">
          <img
            src="/img/logo-idmetal.png"
            alt="IDMETAL"
            class="h-12 w-auto max-w-[160px] object-contain mb-2"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
          />
          <span class="hidden items-center" aria-hidden="true">
            <span class="font-rajdhani font-bold text-2xl text-idm-red tracking-widest">IDM</span>
            <span class="font-rajdhani font-bold text-2xl text-idm-yellow tracking-widest">ETAL</span>
          </span>
          <span class="font-rajdhani text-xs tracking-[0.35em] text-idm-text-muted uppercase">
            LO HACEMOS MEJOR
          </span>
        </a>
        <p class="font-inter text-idm-text-muted text-sm leading-relaxed max-w-sm mt-3">
          Empresa peruana especializada en metalmecánica industrial, construcción civil y
          topografía. Desde Cajamarca, construimos con precisión y calidad garantizada.
        </p>
        <!-- Social icons -->
        <div class="flex gap-3 mt-6">
          {socialLinks.map((s) => (
            <a
              href={s.href}
              aria-label={s.label}
              class="w-9 h-9 border border-white/10 flex items-center justify-center text-idm-text-muted hover:text-white hover:border-idm-red transition-colors duration-200"
              set:html={s.icon}
            />
          ))}
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="font-rajdhani font-bold text-white text-sm tracking-widest uppercase mb-5">
          Navegación
        </h3>
        <ul class="space-y-2.5">
          {navLinks.map((link) => (
            <li>
              <a
                href={`#${link.toLowerCase()}`}
                class="font-inter text-idm-text-muted text-sm hover:text-white transition-colors"
              >
                {link}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="font-rajdhani font-bold text-white text-sm tracking-widest uppercase mb-5">
          Especialidades
        </h3>
        <ul class="space-y-2.5">
          {services.map((s) => (
            <li>
              <a
                href="#servicios"
                class="font-inter text-idm-text-muted text-sm hover:text-white transition-colors"
              >
                {s}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/5 pt-8 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="font-inter text-idm-text-muted text-xs">
        © 2026 IDMETAL. Todos los derechos reservados.
      </p>
      <p class="font-inter text-idm-text-muted text-xs italic">
        Diseñado con precisión. Construido con calidad.
      </p>
    </div>
  </div>
</footer>
