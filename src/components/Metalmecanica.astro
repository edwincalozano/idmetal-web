---
const groups = [
  {
    title: 'Estructuras Ligeras',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>`,
    items: ['Rejas y portones', 'Puertas metálicas', 'Ventanas de fierro', 'Barandas', 'Escaleras simples'],
    img: '/img/1.png',
    imgAlt: 'Galpón industrial',
  },
  {
    title: 'Coberturas & Techos',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>`,
    items: ['Techos livianos', 'Coberturas industriales', 'Galpones metálicos'],
    img: '/img/2.png',
    imgAlt: 'Taller metalmecánico',
  },
  {
    title: 'Estructuras Industriales & Almacenamiento',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20M4 20V10l8-6 8 6v10"/><path d="M12 20v-6"/></svg>`,
    items: ['Cerchas metálicas', 'Estructuras para almacenes', 'Mezanines', 'Mesas y estanterías', 'Soportes metálicos', 'Andamios artesanales', 'Cercos perimétricos'],
    img: '/img/3.png',
    imgAlt: 'Estructura metálica industrial',
  },
  {
    title: 'Soluciones Especializadas',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v4M12 18v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M2 12h4M18 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>`,
    items: ['Torres metálicas', 'Escaleras industriales', 'Tanques simples', 'Estructuras para paneles solares', 'Puentes peatonales livianos', 'Remolques pequeños', 'Tolvas simples', 'Parrillas metálicas'],
    img: '/img/4.png',
    imgAlt: 'Puente metálico',
  },
];
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  {groups.map((group) => (
    <div class="bg-idm-surface border border-white/5 hover:border-idm-red/40 transition-all duration-300 hover:-translate-y-1 group overflow-hidden">
      <div class="relative h-44 overflow-hidden">
        <img
          src={group.img}
          alt={group.imgAlt}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-idm-bg/70"></div>
        <div class="absolute bottom-0 left-0 right-0 p-4 flex items-end gap-3">
          <span class="text-idm-red" set:html={group.icon} />
          <h4 class="font-rajdhani font-bold text-white text-lg leading-tight">{group.title}</h4>
        </div>
      </div>
      <div class="p-5">
        <ul class="space-y-1.5">
          {group.items.map((item) => (
            <li class="flex items-center gap-2 font-inter text-idm-text-muted text-sm">
              <span class="w-1.5 h-1.5 rounded-full bg-idm-red flex-shrink-0" aria-hidden="true"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  ))}
</div>
