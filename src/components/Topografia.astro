---
const serviceGroups = [
  {
    title: 'Levantamiento & Escaneo',
    items: [
      'Levantamiento topográfico con LIDAR',
      'Fotogrametría con drones',
      'Escaneo 3D de estructuras existentes',
      'Elaboración de planos topográficos',
    ],
  },
  {
    title: 'Modelamiento & Procesamiento',
    items: [
      'Modelamiento BIM en Revit desde nube de puntos',
      'Procesamiento de nubes de puntos (Recap, CloudCompare)',
      'Modelos digitales de terreno (MDT/MDE)',
      'Ortofotomapas georreferenciados',
    ],
  },
];

const workflow = ['Terreno', 'Vuelo Drone', 'Nube de Puntos', 'Modelo 3D', 'Planos BIM'];
---

<div class="space-y-8">
  <!-- Section image + copy -->
  <div class="relative h-56 overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1508614999368-9260051292e5?w=1200&q=80"
      alt="Levantamiento topográfico con drone"
      class="w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-idm-bg/65"></div>
    <div class="absolute inset-0 flex items-end p-8">
      <p class="font-inter text-idm-text-light text-base max-w-2xl leading-relaxed italic">
        "Utilizamos tecnología de punta — drones DJI con sensores LIDAR, estaciones totales
        robóticas y software BIM — para entregar levantamientos de precisión milimétrica."
      </p>
    </div>
  </div>

  <!-- Workflow diagram -->
  <div class="bg-idm-surface border border-white/5 p-6">
    <p class="font-inter text-idm-text-muted text-xs uppercase tracking-widest mb-4">Flujo de trabajo</p>
    <div class="flex flex-col sm:flex-row items-center justify-between gap-3 flex-wrap">
      {workflow.map((step, i) => (
        <div class="flex items-center gap-3">
          <div class="flex flex-col items-center">
            <span class="font-inter text-xs text-idm-text-muted mb-1">{`0${i + 1}`}</span>
            <span class="font-rajdhani font-semibold text-white text-sm tracking-wide px-3 py-1.5 border border-idm-red/40 bg-idm-red/10 whitespace-nowrap">
              {step}
            </span>
          </div>
          {i < workflow.length - 1 && (
            <svg class="w-5 h-5 text-idm-red flex-shrink-0 hidden sm:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          )}
        </div>
      ))}
    </div>
  </div>

  <!-- Service groups -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {serviceGroups.map((group) => (
      <div class="bg-idm-surface border border-white/5 hover:border-idm-text-muted/30 transition-all duration-300 p-6">
        <h4 class="font-rajdhani font-bold text-white text-lg mb-4 border-b border-white/10 pb-3">
          {group.title}
        </h4>
        <ul class="space-y-2">
          {group.items.map((item) => (
            <li class="flex items-start gap-2 font-inter text-idm-text-muted text-sm">
              <span class="w-1.5 h-1.5 rounded-full bg-idm-text-muted mt-1.5 flex-shrink-0" aria-hidden="true"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</div>
